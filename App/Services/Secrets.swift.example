// Copy this file to Secrets.swift (same folder) and fill in your key.
// Secrets.swift is gitignored on purpose — never commit it.
//
// Generate the two byte arrays from your Gemini API key by running:
//
//   python3 -c 'import secrets;k=input("key: ").encode();s=secrets.token_bytes(len(k));m=bytes(a^b for a,b in zip(k,s));f=lambda b:", ".join(f"0x{x:02X}" for x in b);print("salt:",f(s));print("mixed:",f(m))'
//
// then paste the printed arrays below.

import Foundation

enum Secrets {
    private static let salt: [UInt8] = [/* paste salt bytes here */]
    private static let mixed: [UInt8] = [/* paste mixed bytes here */]

    /// The Gemini API key, reassembled at runtime.
    static var geminiAPIKey: String {
        String(bytes: zip(mixed, salt).map(^), encoding: .utf8) ?? ""
    }
}
